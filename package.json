{
  "name": "seed4j-cli",
  "version": "0.0.3",
  "private": false,
  "description": "Seed4J CLI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seed4j/seed4j-cli.git"
  },
  "license": "Apache-2.0",
  "bin": {
    "seed4j": "./bin/seed4j.js"
  },
  "files": [
    "bin/",
    "dist/seed4j-cli.jar",
    "LICENSE.txt",
    "README.md"
  ],
  "scripts": {
    "package:prepare": "node scripts/prepare-npm-package.js",
    "prepare": "husky",
    "prettier:check": "prettier --check .",
    "prettier:format": "prettier --write .",
    "test:npm-package": "node --test test/npm/*.test.js"
  },
  "devDependencies": {
    "@prettier/plugin-xml": "3.4.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.8.4",
    "prettier-plugin-gherkin": "4.0.0",
    "prettier-plugin-java": "2.10.0",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-packagejson": "3.0.2"
  },
  "engines": {
    "node": ">=22"
  }
}
